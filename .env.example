# Copiar a `.env` y completar (no commitear `.env`).
# cp .env.example .env

# --- DigitalOcean Spaces (API S3) ---
# Región y endpoint: https://docs.digitalocean.com/products/spaces/
# Ejemplo endpoint: https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Keys del Space (Spaces access keys en el panel de DO)
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=

# Bucket y prefijo opcional dentro del bucket (sin / inicial)
SPACES_BUCKET=
SPACES_PREFIX=

# Dataset outcome predictor en Spaces (procurements.json + ids_*.json del ETL):
# Por defecto el ETL usa SPACES_PREFIX + outcome-predictor/procurements (igual que materialize).
# Para forzar otra ruta completa bajo el bucket:
# DO_SPACES_DATASET_PREFIX=outcome-predictor/procurements
# Legacy / alias:
# DO_SPACES_PREFIX_INPUT=

# Alias que también acepta el ETL (si ya los usás en otro lado):
# DO_SPACES_ACCESS_KEY_ID=  + DO_SPACES_SECRET_ACCESS_KEY=
# DO_SPACES_REGION=  DO_SPACES_ENDPOINT=  DO_SPACES_BUCKET=

# Opcional: perfil / nombre lógico si usás varios buckets
# SPACES_NAME=default
